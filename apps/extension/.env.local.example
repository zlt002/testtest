# Optional local overrides for extension development.
# Copy to .env.local and uncomment only what you need.

# Enable the code inspector only when you actively want Alt/Option+Shift+click
# to jump from the UI to source code in your editor.
# Leaving this unset keeps the plugin disabled and avoids repeated Vite
# sourcemap warnings during normal startup.
# CODE_INSPECTOR=true

# Examples:
# CODE_EDITOR=code
# CODE_EDITOR=/Applications/Windsurf.app/Contents/MacOS/Windsurf
